{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/flow/:path*",
      "destination": "https://your-backend.onrender.com/api/flow/:path*"
    },
    {
      "source": "/api/darkpool/:path*",
      "destination": "https://your-backend.onrender.com/api/darkpool/:path*"
    },
    {
      "source": "/api/gex/:path*",
      "destination": "https://your-backend.onrender.com/api/gex/:path*"
    },
    {
      "source": "/api/chain/:path*",
      "destination": "https://your-backend.onrender.com/api/chain/:path*"
    },
    {
      "source": "/api/health",
      "destination": "https://your-backend.onrender.com/api/health"
    }
  ],
  "env": {
    "NEXT_PUBLIC_WS_URL": "wss://your-backend.onrender.com"
  }
}
