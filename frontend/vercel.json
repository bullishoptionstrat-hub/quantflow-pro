{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/api/flow/:path*",
      "destination": "https://quantflow-pro-backend.onrender.com/api/flow/:path*"
    },
    {
      "source": "/api/darkpool/:path*",
      "destination": "https://quantflow-pro-backend.onrender.com/api/darkpool/:path*"
    },
    {
      "source": "/api/gex/:path*",
      "destination": "https://quantflow-pro-backend.onrender.com/api/gex/:path*"
    },
    {
      "source": "/api/chain/:path*",
      "destination": "https://quantflow-pro-backend.onrender.com/api/chain/:path*"
    },
    {
      "source": "/api/health",
      "destination": "https://quantflow-pro-backend.onrender.com/api/health"
    }
  ]
}
