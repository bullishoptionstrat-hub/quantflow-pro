# ─── Frontend (Next.js) ────────────────────────────────────────────────────────
# Copy to frontend/.env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_ML_URL=http://localhost:8000

# ─── Backend (Node.js Express) ────────────────────────────────────────────────
# Copy to backend/.env

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (service role — server only, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Data Sources
TRADIER_TOKEN=your-tradier-api-token
POLYGON_API_KEY=your-polygon-api-key
ALPACA_KEY=your-alpaca-api-key
ALPACA_SECRET=your-alpaca-api-secret
FINNHUB_API_KEY=your-finnhub-api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key

# Upstash Redis (rate limiting + caching)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── ML Service (Python FastAPI) ─────────────────────────────────────────────
# Copy to ml-service/.env

ML_PORT=8000

# ─── Free API Signup Links ────────────────────────────────────────────────────
# Tradier:       https://developer.tradier.com/user/sign_up
# Polygon:       https://polygon.io/dashboard/signup
# Alpaca:        https://app.alpaca.markets/signup
# Finnhub:       https://finnhub.io/register
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
# Supabase:      https://supabase.com/dashboard/sign-up
# Upstash:       https://upstash.com/
