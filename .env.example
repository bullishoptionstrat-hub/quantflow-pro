# ─── Frontend (Next.js) ────────────────────────────────────────────────────────
# Copy to frontend/.env.local

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_ML_URL=http://localhost:8000

# ─── Backend (Node.js Express) ────────────────────────────────────────────────
# Copy to backend/.env

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (service role — server only, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Core Data Sources ──────────────────────────────────────────────────────────
TRADIER_TOKEN=your-tradier-api-token
POLYGON_API_KEY=your-polygon-api-key
ALPACA_KEY=your-alpaca-api-key
ALPACA_SECRET=your-alpaca-api-secret
FINNHUB_API_KEY=your-finnhub-api-key
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key

# ── 13 New Free API Sources ────────────────────────────────────────────────────
# FlashAlpha — GEX / DEX / VEX
# Sign up: https://flashalpha.com
FLASHALPHA_API_KEY=your-flashalpha-api-key

# MarketData.app — Real options chains (OPRA data)
# Sign up: https://app.marketdata.app/register
MARKETDATA_TOKEN=your-marketdata-app-token

# Schwab Developer API — Free with brokerage account
# Register app: https://developer.schwab.com
SCHWAB_APP_KEY=your-schwab-app-key
SCHWAB_APP_SECRET=your-schwab-app-secret
SCHWAB_REFRESH_TOKEN=your-schwab-oauth-refresh-token

# Tastytrade API — Free with account (options chains + flow)
# Docs: https://developer.tastytrade.com
TASTYTRADE_USER=your-tastytrade-username
TASTYTRADE_PASS=your-tastytrade-password

# Twelve Data — Real-time quotes & WebSocket
# Sign up: https://twelvedata.com/signup
TWELVE_DATA_API_KEY=your-twelvedata-api-key

# Financial Modeling Prep — Earnings, insiders, news
# Sign up: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your-fmp-api-key

# CoinGecko Pro — Crypto prices, global market data
# Sign up: https://www.coingecko.com/en/api/pricing (free demo key available)
COINGECKO_API_KEY=your-coingecko-api-key

# FRED (Federal Reserve) — Macro series (CPI, FFR, PCE, etc.)
# Sign up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key

# Reddit API — WSB + options sentiment via PRAW
# Create app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=QuantFlowPro/1.0 by YourRedditUsername

# NewsAPI — Financial headlines
# Sign up: https://newsapi.org/register
NEWS_API_KEY=your-newsapi-key

# CBOE Data — VIX term structure & put/call ratios (no key needed — public data)
CBOE_ENABLED=true

# Yahoo Finance Fallback — Quote & option flow scraping (no key needed)
YAHOO_ENABLED=true

# Stooq Fallback — Futures, indices, yields CSV (no key needed)
STOOQ_ENABLED=true

# ── Upstash Redis (rate limiting + caching) ───────────────────────────────────
# Sign up: https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── ML Service (Python FastAPI) ─────────────────────────────────────────────
# Copy to ml-service/.env

ML_PORT=8000

